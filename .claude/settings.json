{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Read(docs/**)",
      "Read(src/**)",
      "Read(templates/**)",
      "Read(.claude/**)",
      "Read(pom.xml)",
      "Read(build.gradle)",
      "Read(build.gradle.kts)",
      "Read(settings.gradle)",
      "Read(README.md)",
      "Read(CLAUDE.md)",
      "Edit(docs/**)",
      "Edit(src/**)",
      "Edit(.claude/output-templates/**)",
      "Write(docs/**)",
      "Write(src/**)",
      "Write(.claude/output-templates/**)",
      "Bash(mvn:*)",
      "Bash(./mvnw:*)",
      "Bash(gradle:*)",
      "Bash(./gradlew:*)",
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(rm -rf /:*)",
      "Bash(sudo:*)",
      "Bash(chmod -R 777:*)",
      "Bash(git push --force:*)",
      "Bash(git reset --hard:*)",
      "Edit(.git/**)",
      "Write(.git/**)",
      "Edit(.claude/settings.json)",
      "Write(.claude/settings.json)",
      "Edit(.env)",
      "Edit(.env.local)",
      "Read(.env)",
      "Read(.env.local)"
    ],
    "ask": [
      "Edit(.claude/commands/**)",
      "Write(.claude/commands/**)",
      "Edit(pom.xml)",
      "Edit(build.gradle)",
      "Edit(build.gradle.kts)"
    ]
  }
}
